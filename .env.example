# Required — your Kia Connect / Hyundai Bluelink account
KIA_USERNAME=you@example.com
KIA_PASSWORD=your-account-password

# Optional — required only for remote lock/unlock and a few other commands
KIA_PIN=0000

# Region: 1=Europe, 2=Canada, 3=USA, 4=China, 5=Australia, 6=India, 7=South Korea
KIA_REGION=6

# Brand: 1=Kia, 2=Hyundai, 3=Genesis
KIA_BRAND=1

# Optional — used for fuel cost / mileage estimates
# Tank capacity in liters (default 45 — the Kia Carens). Look up your model.
KIA_TANK_LITERS=45

# Local fuel price per liter (in your currency). Default 105 (INR).
KIA_FUEL_PRICE=105
